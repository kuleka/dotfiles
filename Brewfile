# ========== Shell 核心 ==========
brew "starship"                    # 提示符
brew "zsh-autosuggestions"         # 命令建议
brew "zsh-syntax-highlighting"     # 语法高亮
brew "thefuck"                     # 命令纠错
brew "fzf"                         # 模糊搜索
brew "fd"                          # 更好的 find
brew "yazi"                        # 终端文件管理器

# ========== 字体 ==========
cask "font-maple-mono-nf-cn"       # Maple Mono 字体（含中文和 Nerd Font）
